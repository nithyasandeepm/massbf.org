---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Sponsors">
  <section style="background:linear-gradient(135deg,#1B3A8F 0%,#122970 100%);padding:3rem 1.5rem 2.5rem;color:white;">
    <div style="max-width:1200px;margin:0 auto;">
      <h1 style="font-size:2.2rem;font-weight:800;margin:0 0 0.5rem;">Our Sponsors</h1>
      <p style="font-size:1rem;color:rgba(255,255,255,0.8);margin:0;">Thank you to all who support Massachusetts badminton.</p>
    </div>
  </section>

  <section style="padding:3.5rem 1.5rem;">
    <div style="max-width:1200px;margin:0 auto;">

      <h2 class="mbf-section-title">Supporting Organizations</h2>
      <div style="margin-top:1.5rem;">
        <div class="placeholder-box" style="padding:3.5rem 2rem;text-align:center;">
          <div style="font-size:2.5rem;margin-bottom:1rem;">🏢</div>
          <p style="font-size:1rem;font-weight:600;color:#64748B;margin:0 0 0.4rem;">Coming Soon</p>
          <p style="font-size:0.85rem;color:#94A3B8;margin:0;">Sponsor logos will be displayed here.</p>
        </div>
      </div>

      <div style="margin-top:3rem;text-align:center;">
        <p style="font-size:0.95rem;color:#4B5563;">
          Contact us at <a href="mailto:larryzhang07@gmail.com" style="color:#1B3A8F;font-weight:600;">larryzhang07@gmail.com</a> to discuss sponsorship opportunities.
        </p>
      </div>

    </div>
  </section>
</Layout>
