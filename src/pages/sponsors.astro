---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Sponsors">
  <section style="background:linear-gradient(135deg,#1B3A8F 0%,#122970 100%);padding:3rem 1.5rem 2.5rem;color:white;">
    <div style="max-width:1200px;margin:0 auto;">
      <h1 style="font-size:2.2rem;font-weight:800;margin:0 0 0.5rem;">Our Sponsors</h1>
      <p style="font-size:1rem;color:rgba(255,255,255,0.8);margin:0;">Thank you to all who support Massachusetts badminton.</p>
    </div>
  </section>

  <section style="padding:3.5rem 1.5rem;">
    <div style="max-width:1200px;margin:0 auto;">
      <h2 class="mbf-section-title">Supporting Organizations</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1.5rem;margin-top:1.5rem;">
        {[1,2,3,4].map(() => (
          <div class="placeholder-box" style="padding:2.5rem 1.5rem;aspect-ratio:3/2;">
            <div style="font-size:2rem;margin-bottom:0.5rem;">🏢</div>
            <div style="font-size:0.8rem;">Sponsor logo coming soon</div>
          </div>
        ))}
      </div>

      <div style="margin-top:3rem;background:linear-gradient(135deg,#1B3A8F 0%,#122970 100%);border-radius:16px;padding:3rem;text-align:center;color:white;">
        <div style="font-size:2.5rem;margin-bottom:1rem;">🤝</div>
        <h2 style="font-size:1.75rem;font-weight:800;margin:0 0 1rem;">Become a Sponsor</h2>
        <p style="font-size:1rem;color:rgba(255,255,255,0.85);max-width:560px;margin:0 auto 2rem;line-height:1.7;">Partner with MBF to support the growth of badminton in our community. Your sponsorship directly funds scholarships, tournaments, and youth programs.</p>
        <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:1rem;">
          <a href="/donate" class="mbf-donate-btn" style="font-size:1rem;padding:0.75rem 2rem;">Donate Now</a>
          <a href="mailto:larryzhang07@gmail.com" style="background:rgba(255,255,255,0.15);border:2px solid rgba(255,255,255,0.4);color:white;font-weight:700;padding:0.75rem 2rem;border-radius:6px;text-decoration:none;">Contact Us</a>
        </div>
      </div>

      <div style="margin-top:3rem;">
        <h2 class="mbf-section-title">Sponsorship Opportunities</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.5rem;margin-top:1.5rem;">
          <div class="mbf-card" style="padding:1.75rem;text-align:center;">
            <div style="font-size:1.5rem;margin-bottom:0.75rem;">🥉</div>
            <h3 style="font-size:1rem;font-weight:700;color:#1B3A8F;margin:0 0 0.5rem;">Community Partner</h3>
            <p style="font-size:0.85rem;color:#6B7280;margin:0;line-height:1.55;">Logo on event materials and website recognition.</p>
          </div>
          <div class="mbf-card mbf-card-orange" style="padding:1.75rem;text-align:center;">
            <div style="font-size:1.5rem;margin-bottom:0.75rem;">🥈</div>
            <h3 style="font-size:1rem;font-weight:700;color:#1B3A8F;margin:0 0 0.5rem;">Silver Sponsor</h3>
            <p style="font-size:0.85rem;color:#6B7280;margin:0;line-height:1.55;">Banner at tournaments + Community Partner benefits.</p>
          </div>
          <div class="mbf-card mbf-card-red" style="padding:1.75rem;text-align:center;">
            <div style="font-size:1.5rem;margin-bottom:0.75rem;">🥇</div>
            <h3 style="font-size:1rem;font-weight:700;color:#1B3A8F;margin:0 0 0.5rem;">Gold Sponsor</h3>
            <p style="font-size:0.85rem;color:#6B7280;margin:0;line-height:1.55;">Named tournament sponsorship + all Silver benefits.</p>
          </div>
        </div>
        <p style="font-size:0.85rem;color:#94A3B8;text-align:center;margin-top:1.25rem;">Contact us at larryzhang07@gmail.com to discuss sponsorship opportunities.</p>
      </div>
    </div>
  </section>
</Layout>
