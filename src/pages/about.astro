---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About Us">

  <!-- Page Header -->
  <section style="background:linear-gradient(135deg,#1B3A8F 0%,#122970 100%);padding:3rem 1.5rem 2.5rem;color:white;">
    <div style="max-width:1200px;margin:0 auto;">
      <h1 style="font-size:2.2rem;font-weight:800;margin:0 0 0.5rem;">About Us</h1>
      <p style="font-size:1rem;color:rgba(255,255,255,0.8);margin:0;">Learn about our mission and the people behind MBF.</p>
    </div>
  </section>

  <section style="padding:3.5rem 1.5rem;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2.5rem;">

        <!-- Mission -->
        <div>
          <h2 class="mbf-section-title">Our Mission</h2>
          <div class="mbf-card" style="padding:1.75rem;">
            <p style="font-size:1rem;color:#374151;line-height:1.8;margin:0 0 1rem;">
              To promote the sport of badminton in Massachusetts through education, training, events, and community programs that encourage participation, competition, and healthy living styles.
            </p>
            <p style="font-size:0.9rem;color:#6B7280;line-height:1.7;margin:0;font-style:italic;border-top:1px solid #E5E7EB;padding-top:1rem;">
              All personnel of the organization are volunteers. Raised funds will be 100% for the cause.
            </p>
          </div>
        </div>

        <!-- Officers -->
        <div>
          <h2 class="mbf-section-title">Our Officers</h2>
          <div style="display:flex;flex-direction:column;gap:1rem;">
            {[
              { name: "Lanju (Larry) Zhang", role: "Director", icon: "👤" },
              { name: "Satish Donga", role: "Treasurer", icon: "👤" },
              { name: "Nick Waller", role: "Clerk", icon: "👤" },
            ].map(officer => (
              <div class="mbf-card" style="padding:1.25rem 1.5rem;display:flex;align-items:center;gap:1rem;">
                <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#1B3A8F,#3A5FB0);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;">
                  {officer.icon}
                </div>
                <div>
                  <div style="font-weight:700;color:#1B3A8F;font-size:0.95rem;">{officer.name}</div>
                  <div style="font-size:0.82rem;color:#6B7280;text-transform:uppercase;letter-spacing:0.05em;">{officer.role}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- Donation Usage -->
      <div style="margin-top:3rem;">
        <h2 class="mbf-section-title">How Your Donation Helps</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;margin-top:1.5rem;">

          <div class="mbf-card mbf-card-orange" style="padding:1.5rem;">
            <h3 style="font-size:0.95rem;font-weight:700;color:#1B3A8F;margin:0 0 0.6rem;">🏅 Competition Scholarship</h3>
            <p style="font-size:0.88rem;color:#4B5563;margin:0;line-height:1.6;">An MA State Team may be nominated for national tournaments (e.g., Junior National Championship, Open Regional Championship) and international tournaments (e.g., Pan America Championship). Teams may include a boy and girl in each age group (U11, U13, etc.).</p>
          </div>

          <div class="mbf-card mbf-card-red" style="padding:1.5rem;">
            <h3 style="font-size:0.95rem;font-weight:700;color:#1B3A8F;margin:0 0 0.6rem;">🏸 Tournament Sponsorship</h3>
            <p style="font-size:0.88rem;color:#4B5563;margin:0;line-height:1.6;">Funds may be used to sponsor local badminton tournaments or competitions, including college-organized events (e.g., MIT, Harvard).</p>
          </div>

          <div class="mbf-card" style="padding:1.5rem;">
            <h3 style="font-size:0.95rem;font-weight:700;color:#1B3A8F;margin:0 0 0.6rem;">🎓 Badminton Workshop</h3>
            <p style="font-size:0.88rem;color:#4B5563;margin:0;line-height:1.6;">Funds may be used to sponsor nationally or internationally renowned coaches or professional players to visit MA badminton clubs — providing opportunities for students and players to learn from top professionals.</p>
          </div>

          <div class="mbf-card mbf-card-orange" style="padding:1.5rem;">
            <h3 style="font-size:0.95rem;font-weight:700;color:#1B3A8F;margin:0 0 0.6rem;">🌱 Promotional Events</h3>
            <p style="font-size:0.88rem;color:#4B5563;margin:0;line-height:1.6;">Funds may be used to sponsor badminton events in local high schools, colleges, and communities to cultivate badminton outreach in a grassroots approach.</p>
          </div>

        </div>
      </div>

      <!-- Legal Info -->
      <div style="margin-top:2.5rem;background:white;border-radius:12px;padding:1.5rem 2rem;box-shadow:0 2px 12px rgba(27,58,143,0.07);display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
        <div style="font-size:2rem;">📋</div>
        <div>
          <div style="font-weight:700;color:#1B3A8F;margin-bottom:0.25rem;">Legal & Tax Information</div>
          <div style="font-size:0.88rem;color:#6B7280;line-height:1.6;">
            Massachusetts Badminton Foundation (MBF) is registered in Massachusetts with <strong>EIN: 39-4717851</strong>. MBF is a 501(c)(3) tax-exempt organization under the Internal Revenue Code, and contributions are deductible to the fullest extent of the law.
          </div>
        </div>
        <div style="margin-left:auto;">
          <a href="/donate" class="mbf-donate-btn">Donate Now</a>
        </div>
      </div>

    </div>
  </section>

</Layout>
