---
import Layout from "../layouts/Layout.astro";

const tournaments = [
  {
    name: "Wayside Closed Regional Championships 2026",
    status: "upcoming",
    date: "2026",
    location: "Massachusetts",
    description: "The Wayside Closed Regional Championships is a prestigious regional badminton tournament bringing together top players from across Massachusetts and the surrounding region.",
    categories: ["Singles", "Doubles", "Mixed Doubles"],
  },
];
---

<Layout title="Events">

  <!-- Page Header -->
  <section style="background:linear-gradient(135deg,#1B3A8F 0%,#122970 100%);padding:3rem 1.5rem 2.5rem;color:white;">
    <div style="max-width:1200px;margin:0 auto;">
      <h1 style="font-size:2.2rem;font-weight:800;margin:0 0 0.5rem;">Events & Tournaments</h1>
      <p style="font-size:1rem;color:rgba(255,255,255,0.8);margin:0;">Official MBF-sanctioned tournaments and badminton events.</p>
    </div>
  </section>

  <section style="padding:3.5rem 1.5rem;">
    <div style="max-width:1200px;margin:0 auto;">

      <h2 class="mbf-section-title">Tournaments</h2>

      <div style="display:flex;flex-direction:column;gap:1.5rem;margin-top:1.5rem;">
        {tournaments.map(t => (
          <div class="mbf-card" style="padding:0;overflow:hidden;">
            <div style="display:flex;flex-wrap:wrap;">
              <!-- Color sidebar -->
              <div style="width:8px;background:linear-gradient(180deg,#F37021,#CC2222);flex-shrink:0;"></div>
              <div style="padding:1.75rem;flex:1;">
                <div style="display:flex;flex-wrap:wrap;align-items:flex-start;gap:1rem;margin-bottom:1rem;">
                  <div style="flex:1;min-width:200px;">
                    <div style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;margin-bottom:0.5rem;">
                      <h3 style="font-size:1.2rem;font-weight:700;color:#1B3A8F;margin:0;">{t.name}</h3>
                      <span class={`mbf-badge mbf-badge-${t.status}`}>
                        {t.status === "upcoming" ? "Upcoming" : "Past"}
                      </span>
                    </div>
                    <div style="display:flex;gap:1.5rem;flex-wrap:wrap;margin-bottom:0.75rem;">
                      <span style="font-size:0.88rem;color:#6B7280;display:flex;align-items:center;gap:0.3rem;">
                        📅 {t.date}
                      </span>
                      <span style="font-size:0.88rem;color:#6B7280;display:flex;align-items:center;gap:0.3rem;">
                        📍 {t.location}
                      </span>
                    </div>
                    <p style="font-size:0.9rem;color:#4B5563;margin:0;line-height:1.65;">{t.description}</p>
                  </div>
                </div>
                <div style="border-top:1px solid #F0F4FB;padding-top:1rem;display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center;">
                  <span style="font-size:0.8rem;color:#6B7280;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;margin-right:0.25rem;">Categories:</span>
                  {t.categories.map(cat => (
                    <span style="background:#EEF2FF;color:#3730A3;font-size:0.78rem;font-weight:600;padding:0.2rem 0.65rem;border-radius:999px;">{cat}</span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- More Events Notice -->
      <div class="placeholder-box" style="padding:3rem;margin-top:2rem;">
        <div style="font-size:2.5rem;margin-bottom:0.75rem;">📅</div>
        <p style="font-size:1rem;font-weight:600;color:#64748B;margin:0 0 0.5rem;">More Events Coming Soon</p>
        <p style="font-size:0.88rem;color:#94A3B8;margin:0;">Stay tuned for upcoming tournaments and MBF-sponsored events.</p>
      </div>

    </div>
  </section>

</Layout>
