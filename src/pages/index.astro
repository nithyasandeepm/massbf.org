---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Home">

  <!-- Hero Section -->
  <section class="mbf-hero" style="padding:4rem 1.5rem 3.5rem;">
    <div style="max-width:1200px;margin:0 auto;">
      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:3rem;">
        <div style="flex:1;min-width:280px;">
          <div style="display:inline-block;background:rgba(243,112,33,0.2);border:1px solid rgba(243,112,33,0.4);color:#F37021;font-size:0.78rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:0.3rem 0.8rem;border-radius:999px;margin-bottom:1rem;">
            Promoting Badminton in Massachusetts
          </div>
          <h1 style="font-size:2.5rem;font-weight:800;color:#fff;line-height:1.15;margin:0 0 1rem;">
            Massachusetts<br /><span style="color:#F37021;">Badminton Foundation</span>
          </h1>
          <p style="font-size:1.1rem;color:rgba(255,255,255,0.85);line-height:1.7;margin:0 0 2rem;max-width:520px;">
            Promoting the sport of badminton through education, training, events, and community programs that encourage participation, competition, and healthy living.
          </p>
          <div style="display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="/about" style="background:#fff;color:#1B3A8F;font-weight:700;padding:0.75rem 1.75rem;border-radius:6px;text-decoration:none;transition:all 0.2s;box-shadow:0 2px 8px rgba(0,0,0,0.2);">
              Learn More
            </a>
            <a href="/donate" class="mbf-donate-btn" style="padding:0.75rem 1.75rem;">
              Donate Now
            </a>
          </div>
        </div>
        <div style="flex:0 0 auto;">
          <img src="/logo.png" alt="MBF Logo" style="height:220px;width:auto;filter:drop-shadow(0 8px 24px rgba(0,0,0,0.3));" />
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section style="background:#fff;border-bottom:1px solid #E8EDF5;padding:1.5rem;">
    <div style="max-width:1200px;margin:0 auto;display:flex;flex-wrap:wrap;gap:2rem;justify-content:center;text-align:center;">
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:#1B3A8F;">501(c)(3)</div>
        <div style="font-size:0.85rem;color:#6B7280;">Tax-Exempt Organization</div>
      </div>
      <div style="width:1px;background:#E8EDF5;"></div>
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:#F37021;">100%</div>
        <div style="font-size:0.85rem;color:#6B7280;">Funds Go to the Cause</div>
      </div>
      <div style="width:1px;background:#E8EDF5;"></div>
      <div>
        <div style="font-size:1.75rem;font-weight:800;color:#CC2222;">All Volunteers</div>
        <div style="font-size:0.85rem;color:#6B7280;">Personnel are Volunteers</div>
      </div>
    </div>
  </section>

  <!-- Programs Section -->
  <section style="padding:4rem 1.5rem;">
    <div style="max-width:1200px;margin:0 auto;">
      <h2 class="mbf-section-title">What We Do</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.5rem;margin-top:2rem;">

        <div class="mbf-card mbf-card-orange" style="padding:1.5rem;">
          <div style="font-size:2rem;margin-bottom:0.75rem;">🏆</div>
          <h3 style="font-size:1.05rem;font-weight:700;color:#1B3A8F;margin:0 0 0.5rem;">Scholarship Program</h3>
          <p style="font-size:0.9rem;color:#4B5563;margin:0;line-height:1.6;">Supporting MA State Teams nominated for national and international tournaments including Junior National Championship and Pan America Championship.</p>
        </div>

        <div class="mbf-card mbf-card-red" style="padding:1.5rem;">
          <div style="font-size:2rem;margin-bottom:0.75rem;">🏸</div>
          <h3 style="font-size:1.05rem;font-weight:700;color:#1B3A8F;margin:0 0 0.5rem;">Tournament Sponsorship</h3>
          <p style="font-size:0.9rem;color:#4B5563;margin:0;line-height:1.6;">Sponsoring local badminton tournaments and competitions, including college-organized events at MIT, Harvard, and other institutions.</p>
        </div>

        <div class="mbf-card" style="padding:1.5rem;">
          <div style="font-size:2rem;margin-bottom:0.75rem;">🎓</div>
          <h3 style="font-size:1.05rem;font-weight:700;color:#1B3A8F;margin:0 0 0.5rem;">Badminton Workshops</h3>
          <p style="font-size:0.9rem;color:#4B5563;margin:0;line-height:1.6;">Bringing nationally and internationally renowned coaches and professional players to Massachusetts clubs for learning and interaction.</p>
        </div>

        <div class="mbf-card mbf-card-orange" style="padding:1.5rem;">
          <div style="font-size:2rem;margin-bottom:0.75rem;">🌱</div>
          <h3 style="font-size:1.05rem;font-weight:700;color:#1B3A8F;margin:0 0 0.5rem;">Community Outreach</h3>
          <p style="font-size:0.9rem;color:#4B5563;margin:0;line-height:1.6;">Sponsoring badminton events in local high schools, colleges, and communities to cultivate badminton at the grassroots level.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Donate CTA -->
  <section style="background:linear-gradient(135deg,#1B3A8F 0%,#122970 100%);padding:4rem 1.5rem;text-align:center;">
    <div style="max-width:700px;margin:0 auto;">
      <h2 style="font-size:2rem;font-weight:800;color:#fff;margin:0 0 1rem;">Support Massachusetts Badminton</h2>
      <p style="font-size:1rem;color:rgba(255,255,255,0.85);margin:0 0 2rem;line-height:1.7;">
        MBF is a 501(c)(3) tax-exempt organization. All donations go directly to the cause — 100% for badminton programs in Massachusetts.
      </p>
      <a href="/donate" class="mbf-donate-btn" style="font-size:1.05rem;padding:0.85rem 2.5rem;">
        Donate via Zeffy →
      </a>
      <p style="font-size:0.8rem;color:rgba(255,255,255,0.55);margin-top:1rem;">EIN: 39-4717851 | Contributions are tax-deductible</p>
    </div>
  </section>

</Layout>
