---
import Layout from "../layouts/Layout.astro";
---

<Layout title="HB PCA">
  <section style="background:linear-gradient(135deg,#1B3A8F 0%,#122970 100%);padding:3rem 1.5rem 2.5rem;color:white;">
    <div style="max-width:1200px;margin:0 auto;">
      <h1 style="font-size:2.2rem;font-weight:800;margin:0 0 0.5rem;">HelloBirdie Parent Coach Association</h1>
      <p style="font-size:1rem;color:rgba(255,255,255,0.85);margin:0;max-width:760px;line-height:1.7;">
        The mission of the HelloBirdie Parent Coach Association (HB PCA) is to foster and create a positive environment where kids can become highly motivated and engaged and grow together in their badminton skills.
      </p>
    </div>
  </section>

  <section style="padding:3.5rem 1.5rem;">
    <div style="max-width:1200px;margin:0 auto;">

      <!-- ── Community Events (Birthday + Potluck combined) ──────── -->
      <div style="margin-bottom:3.5rem;">
        <h2 class="mbf-section-title">🎉 Community Events</h2>
        <p style="font-size:0.95rem;color:#4B5563;margin-bottom:1.5rem;">Celebrations, potlucks, and gatherings that bring our MBF community together.</p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.25rem;">

          <div class="mbf-card mbf-card-red" style="padding:1.5rem;display:flex;align-items:flex-start;gap:1rem;">
            <div style="font-size:1.75rem;flex-shrink:0;">🎂</div>
            <div>
              <h3 style="font-size:0.95rem;font-weight:700;color:#1B3A8F;margin:0 0 0.4rem;">Birthday Celebrations</h3>
              <p style="font-size:0.85rem;color:#6B7280;margin:0;line-height:1.55;">We love celebrating our players' birthdays as a community! Everyone gets a moment to shine.</p>
            </div>
          </div>

          <div class="mbf-card mbf-card-orange" style="padding:1.5rem;display:flex;align-items:flex-start;gap:1rem;">
            <div style="font-size:1.75rem;flex-shrink:0;">🍱</div>
            <div>
              <h3 style="font-size:0.95rem;font-weight:700;color:#1B3A8F;margin:0 0 0.4rem;">Annual Potluck Dinner</h3>
              <p style="font-size:0.85rem;color:#6B7280;margin:0;line-height:1.55;">A beloved tradition where players and their families share home-cooked dishes and celebrate the badminton season.</p>
            </div>
          </div>

          <div class="mbf-card" style="padding:1.5rem;display:flex;align-items:flex-start;gap:1rem;">
            <div style="font-size:1.75rem;flex-shrink:0;">🎊</div>
            <div>
              <h3 style="font-size:0.95rem;font-weight:700;color:#1B3A8F;margin:0 0 0.4rem;">Seasonal Celebrations</h3>
              <p style="font-size:0.85rem;color:#6B7280;margin:0;line-height:1.55;">Holiday gatherings and end-of-season celebrations that bring the MBF community together off the court.</p>
            </div>
          </div>

          <div class="mbf-card mbf-card-orange" style="padding:1.5rem;display:flex;align-items:flex-start;gap:1rem;">
            <div style="font-size:1.75rem;flex-shrink:0;">👥</div>
            <div>
              <h3 style="font-size:0.95rem;font-weight:700;color:#1B3A8F;margin:0 0 0.4rem;">Community Meetups</h3>
              <p style="font-size:0.85rem;color:#6B7280;margin:0;line-height:1.55;">Casual get-togethers for players of all levels to connect, share experiences, and grow as a community.</p>
            </div>
          </div>

        </div>
      </div>

      <!-- ── Event Gallery ───────────────────────────────────────── -->
      <div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;flex-wrap:wrap;gap:0.75rem;">
          <h2 class="mbf-section-title" style="margin:0;">📸 Event Gallery</h2>
          <label id="gallery-upload-label" style="display:none;background:#1B3A8F;color:white;padding:0.45rem 1.1rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.82rem;">
            ⬆ Upload Photos
            <input type="file" id="gallery-file" accept="image/*" multiple style="display:none;" onchange="uploadPhotos('gallery',this)" />
          </label>
        </div>
        <p style="font-size:0.95rem;color:#4B5563;margin-bottom:1.25rem;">Highlights and memories from our community events.</p>
        <div id="gallery-upload-status" style="display:none;font-size:0.85rem;color:#1B3A8F;margin-bottom:0.75rem;font-weight:600;padding:0.6rem 0.9rem;background:#EFF6FF;border-radius:6px;border:1px solid #BFDBFE;"></div>
        <div id="gallery-photos" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:0.85rem;">
          <div class="placeholder-box" style="aspect-ratio:4/3;padding:1rem;">
            <div style="font-size:2rem;">📷</div>
            <div style="font-size:0.75rem;margin-top:0.5rem;">Photos coming soon</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    let isAdmin = false;

    function showAdminControls() {
      isAdmin = true;
      const lbl = document.getElementById('gallery-upload-label')!;
      if (lbl) lbl.style.display = 'inline-block';
      loadPhotos('gallery');
    }
    document.addEventListener('mbf:admin-ready', showAdminControls);
    if (document.body.dataset.admin === 'true') showAdminControls();

    async function loadPhotos(type: string) {
      const container = document.getElementById(`${type}-photos`)!;
      try {
        const res = await fetch(`/api/photos?type=${type}`);
        const photos: string[] = await res.json();
        if (!photos.length) {
          container.innerHTML = `<div class="placeholder-box" style="aspect-ratio:4/3;padding:1rem;">
            <div style="font-size:2rem;">${type === 'birthday' ? '🎂' : '📷'}</div>
            <div style="font-size:0.75rem;margin-top:0.5rem;">Photos coming soon</div></div>`;
        } else {
          container.innerHTML = photos.map(url => {
            const filename = url.split('/').pop() || '';
            const delBtn = isAdmin
              ? `<button onclick="deletePhoto('${type}','${filename}')"
                  title="Delete photo"
                  style="position:absolute;top:6px;right:6px;background:rgba(204,34,34,0.88);color:white;border:none;border-radius:5px;padding:0.22rem 0.48rem;font-size:0.72rem;font-weight:700;cursor:pointer;line-height:1.2;">✕</button>`
              : '';
            return `<div style="position:relative;aspect-ratio:4/3;overflow:hidden;border-radius:8px;background:#f8fafc;">
              <img src="${url}" alt="Photo" style="width:100%;height:100%;object-fit:cover;" loading="lazy" />
              ${delBtn}</div>`;
          }).join('');
        }
      } catch {}
    }

    window.uploadPhotos = async function(type: string, input: HTMLInputElement) {
      const files = input.files;
      if (!files || !files.length) return;
      const count = Math.min(files.length, 100);
      const statusEl = document.getElementById(`${type}-upload-status`)!;
      statusEl.style.display = 'block';
      statusEl.style.color = '#1B3A8F';
      statusEl.style.borderColor = '#BFDBFE';
      statusEl.style.background = '#EFF6FF';
      const token = sessionStorage.getItem('mbf_admin_token');
      let uploaded = 0, failed = 0;
      for (let i = 0; i < count; i++) {
        statusEl.textContent = `Uploading photo ${i + 1} of ${count}…`;
        const formData = new FormData();
        formData.append('type', type);
        formData.append('file', files[i]);
        try {
          const res = await fetch('/api/upload', { method: 'POST', headers: { 'X-Admin-Token': token || '' }, body: formData });
          if (res.ok) uploaded++; else failed++;
        } catch { failed++; }
      }
      if (failed === 0) {
        statusEl.textContent = `✓ ${uploaded} photo${uploaded !== 1 ? 's' : ''} uploaded successfully!`;
      } else {
        statusEl.textContent = `${uploaded} uploaded, ${failed} failed.`;
        statusEl.style.color = '#CC2222'; statusEl.style.background = '#FEF2F2'; statusEl.style.borderColor = '#FECACA';
      }
      setTimeout(() => { statusEl.style.display = 'none'; }, 4000);
      input.value = '';
      await loadPhotos(type);
    };

    window.deletePhoto = async function(type: string, filename: string) {
      const confirmed = await window.mbfConfirm('This photo will be permanently deleted.', 'Delete Photo?', 'Delete', '🖼️');
      if (!confirmed) return;
      const token = sessionStorage.getItem('mbf_admin_token');
      const res = await fetch(`/api/photos?type=${type}&file=${filename}`, { method: 'DELETE', headers: { 'X-Admin-Token': token || '' } });
      if (res.ok) await loadPhotos(type);
    };

    loadPhotos('gallery');
  </script>
</Layout>
