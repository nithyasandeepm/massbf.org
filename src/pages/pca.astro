---
import Layout from "../layouts/Layout.astro";
---

<Layout title="PCA">
  <section style="background:linear-gradient(135deg,#1B3A8F 0%,#122970 100%);padding:3rem 1.5rem 2.5rem;color:white;">
    <div style="max-width:1200px;margin:0 auto;">
      <h1 style="font-size:2.2rem;font-weight:800;margin:0 0 0.5rem;">Parent Coach Association</h1>
      <p style="font-size:1rem;color:rgba(255,255,255,0.85);margin:0;max-width:760px;line-height:1.7;">
        The mission of the Parent Coach Association (PCA) is to foster and create a positive environment where kids can become highly motivated and engaged and grow together in their badminton skills.
      </p>
    </div>
  </section>

  <section style="padding:3.5rem 1.5rem;">
    <div style="max-width:1200px;margin:0 auto;">

      <!-- Birthday Celebrations -->
      <div style="margin-bottom:3.5rem;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;flex-wrap:wrap;gap:0.75rem;">
          <h2 class="mbf-section-title" style="margin:0;">🎂 Birthday Celebrations</h2>
          <label
            id="birthday-upload-label"
            style="display:none;background:#1B3A8F;color:white;border:none;padding:0.5rem 1.25rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.85rem;"
          >
            ⬆ Upload Photo
            <input type="file" id="birthday-file" accept="image/*" style="display:none;" onchange="uploadPhoto('birthday',this)" />
          </label>
        </div>
        <p style="font-size:0.95rem;color:#4B5563;margin-bottom:1.5rem;">We love celebrating our players' birthdays as a community!</p>
        <div id="birthday-upload-status" style="display:none;font-size:0.85rem;color:#1B3A8F;margin-bottom:1rem;font-weight:600;"></div>
        <div id="birthday-photos" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;">
          <div class="placeholder-box" style="aspect-ratio:4/3;padding:1rem;">
            <div style="font-size:2rem;">🎂</div>
            <div style="font-size:0.75rem;margin-top:0.5rem;">Photos coming soon</div>
          </div>
        </div>
      </div>

      <!-- Potlucks & Gatherings -->
      <div style="margin-bottom:3.5rem;">
        <h2 class="mbf-section-title">🍽️ Potlucks & Gatherings</h2>
        <p style="font-size:0.95rem;color:#4B5563;margin-bottom:1.5rem;">Our community potlucks and social gatherings bring players and families together.</p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.25rem;">
          <div class="mbf-card mbf-card-orange" style="padding:1.5rem;display:flex;align-items:flex-start;gap:1rem;">
            <div style="font-size:1.75rem;flex-shrink:0;">🍱</div>
            <div>
              <h3 style="font-size:0.95rem;font-weight:700;color:#1B3A8F;margin:0 0 0.4rem;">Annual Potluck Dinner</h3>
              <p style="font-size:0.85rem;color:#6B7280;margin:0;line-height:1.55;">A beloved tradition where players and their families share home-cooked dishes and celebrate the badminton season.</p>
            </div>
          </div>
          <div class="mbf-card mbf-card-red" style="padding:1.5rem;display:flex;align-items:flex-start;gap:1rem;">
            <div style="font-size:1.75rem;flex-shrink:0;">🎉</div>
            <div>
              <h3 style="font-size:0.95rem;font-weight:700;color:#1B3A8F;margin:0 0 0.4rem;">Seasonal Celebrations</h3>
              <p style="font-size:0.85rem;color:#6B7280;margin:0;line-height:1.55;">Holiday gatherings and end-of-season celebrations that bring the MBF community together off the court.</p>
            </div>
          </div>
          <div class="mbf-card" style="padding:1.5rem;display:flex;align-items:flex-start;gap:1rem;">
            <div style="font-size:1.75rem;flex-shrink:0;">👥</div>
            <div>
              <h3 style="font-size:0.95rem;font-weight:700;color:#1B3A8F;margin:0 0 0.4rem;">Community Meetups</h3>
              <p style="font-size:0.85rem;color:#6B7280;margin:0;line-height:1.55;">Casual get-togethers for players of all levels to connect, share experiences, and grow as a community.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Photo Gallery -->
      <div>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;flex-wrap:wrap;gap:0.75rem;">
          <h2 class="mbf-section-title" style="margin:0;">📸 Photo Gallery</h2>
          <label
            id="gallery-upload-label"
            style="display:none;background:#1B3A8F;color:white;border:none;padding:0.5rem 1.25rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.85rem;"
          >
            ⬆ Upload Photo
            <input type="file" id="gallery-file" accept="image/*" style="display:none;" onchange="uploadPhoto('gallery',this)" />
          </label>
        </div>
        <p style="font-size:0.95rem;color:#4B5563;margin-bottom:1.5rem;">Highlights and memories from our community events.</p>
        <div id="gallery-upload-status" style="display:none;font-size:0.85rem;color:#1B3A8F;margin-bottom:1rem;font-weight:600;"></div>
        <div id="gallery-photos" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;">
          <div class="placeholder-box" style="aspect-ratio:4/3;padding:1rem;">
            <div style="font-size:2rem;">📷</div>
            <div style="font-size:0.75rem;margin-top:0.5rem;">Photos coming soon</div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <script>
    function showAdminControls() {
      const bdLabel = document.getElementById('birthday-upload-label')!;
      const galLabel = document.getElementById('gallery-upload-label')!;
      if (bdLabel) bdLabel.style.display = 'inline-block';
      if (galLabel) galLabel.style.display = 'inline-block';
    }

    document.addEventListener('mbf:admin-ready', showAdminControls);
    if (document.body.dataset.admin === 'true') showAdminControls();

    async function loadPhotos(type: string) {
      const container = document.getElementById(`${type}-photos`)!;
      try {
        const res = await fetch(`/api/photos?type=${type}`);
        const photos: string[] = await res.json();
        if (photos.length === 0) {
          container.innerHTML = `
            <div class="placeholder-box" style="aspect-ratio:4/3;padding:1rem;">
              <div style="font-size:2rem;">${type === 'birthday' ? '🎂' : '📷'}</div>
              <div style="font-size:0.75rem;margin-top:0.5rem;">Photos coming soon</div>
            </div>`;
        } else {
          container.innerHTML = photos.map(url =>
            `<div style="aspect-ratio:4/3;overflow:hidden;border-radius:8px;background:#f8fafc;">
               <img src="${url}" alt="Photo" style="width:100%;height:100%;object-fit:cover;" loading="lazy" />
             </div>`
          ).join('');
        }
      } catch {}
    }

    window.uploadPhoto = async function(type: string, input: HTMLInputElement) {
      const file = input.files?.[0];
      if (!file) return;
      const statusEl = document.getElementById(`${type}-upload-status`)!;
      statusEl.style.display = 'block';
      statusEl.textContent = 'Uploading…';

      const token = sessionStorage.getItem('mbf_admin_token');
      const formData = new FormData();
      formData.append('type', type);
      formData.append('file', file);

      try {
        const res = await fetch('/api/upload', {
          method: 'POST',
          headers: { 'X-Admin-Token': token || '' },
          body: formData
        });
        if (res.ok) {
          statusEl.textContent = 'Upload successful!';
          setTimeout(() => { statusEl.style.display = 'none'; }, 3000);
          await loadPhotos(type);
        } else {
          statusEl.textContent = 'Upload failed. Please try again.';
          statusEl.style.color = '#CC2222';
        }
      } catch {
        statusEl.textContent = 'Upload failed. Please try again.';
        statusEl.style.color = '#CC2222';
      }
      input.value = '';
    };

    loadPhotos('birthday');
    loadPhotos('gallery');
  </script>
</Layout>
