---
import "./global.css";

interface Props {
  title?: string;
}

const { title = "Massachusetts Badminton Foundation" } = Astro.props;
const path = Astro.url.pathname;

const navLinks = [
  { label: "Home", href: "/" },
  { label: "About Us", href: "/about" },
  { label: "Events", href: "/events" },
  { label: "PCA", href: "/pca" },
  { label: "Sponsors", href: "/sponsors" },
];

function isActive(href: string) {
  if (href === "/") return path === "/";
  return path.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Massachusetts Badminton Foundation</title>
  </head>
  <body style="display:flex;flex-direction:column;min-height:100vh;">

    <header class="mbf-header">
      <div style="max-width:1200px;margin:0 auto;padding:0 1.5rem;">

        <div style="display:flex;align-items:center;gap:1rem;padding:0.75rem 0;flex-wrap:wrap;">
          <!-- Logo + Name -->
          <a href="/" style="display:flex;align-items:center;gap:0.75rem;text-decoration:none;flex-shrink:0;">
            <img src="/logo.png" alt="MBF Logo" style="height:52px;width:auto;object-fit:contain;" />
            <div style="line-height:1.2;">
              <div style="font-size:1.1rem;font-weight:800;color:#fff;letter-spacing:0.02em;">Massachusetts</div>
              <div style="font-size:0.85rem;font-weight:500;color:rgba(255,255,255,0.8);letter-spacing:0.08em;text-transform:uppercase;">Badminton Foundation</div>
            </div>
          </a>

          <div style="flex:1;"></div>

          <!-- Desktop Nav -->
          <nav style="display:flex;align-items:center;gap:0.25rem;">
            {navLinks.map(link => (
              <a
                href={link.href}
                class={`mbf-nav-link ${isActive(link.href) ? "active" : ""}`}
              >
                {link.label}
              </a>
            ))}
            <a href="/donate" class="mbf-donate-btn" style="margin-left:0.75rem;">Donate</a>
          </nav>
        </div>

      </div>
    </header>

    <main style="flex:1;">
      <slot />
    </main>

    <footer class="mbf-footer" style="padding:2rem 0;">
      <div style="max-width:1200px;margin:0 auto;padding:0 1.5rem;">
        <div style="display:flex;flex-wrap:wrap;gap:2rem;justify-content:space-between;align-items:flex-start;">
          <div>
            <img src="/logo.png" alt="MBF Logo" style="height:44px;width:auto;margin-bottom:0.75rem;opacity:0.9;" />
            <p style="font-size:0.85rem;margin:0.25rem 0;">Massachusetts Badminton Foundation</p>
            <p style="font-size:0.8rem;margin:0.25rem 0;opacity:0.7;">EIN: 39-4717851 | 501(c)(3) Tax-Exempt Organization</p>
          </div>
          <div style="font-size:0.85rem;">
            <p style="margin:0.25rem 0;font-weight:600;color:rgba(255,255,255,0.95);">Contact</p>
            <p style="margin:0.25rem 0;opacity:0.8;">80 Broadmeadow Street, Marlborough, MA 01752</p>
            <p style="margin:0.25rem 0;opacity:0.8;">larryzhang07@gmail.com</p>
          </div>
          <div style="font-size:0.85rem;">
            <p style="margin:0.25rem 0;font-weight:600;color:rgba(255,255,255,0.95);">Quick Links</p>
            {navLinks.map(link => (
              <a href={link.href} style="display:block;margin:0.2rem 0;color:rgba(255,255,255,0.7);text-decoration:none;transition:color 0.2s;" onmouseover="this.style.color='#F37021'" onmouseout="this.style.color='rgba(255,255,255,0.7)'">{link.label}</a>
            ))}
          </div>
        </div>
        <div style="border-top:1px solid rgba(255,255,255,0.15);margin-top:1.5rem;padding-top:1rem;font-size:0.78rem;opacity:0.6;text-align:center;">
          &copy; {new Date().getFullYear()} Massachusetts Badminton Foundation. All rights reserved.
        </div>
      </div>
    </footer>

  </body>
</html>
