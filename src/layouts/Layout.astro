---
import "./global.css";
import { readFile } from "node:fs/promises";
import { join } from "node:path";

interface Props {
  title?: string;
}

const { title = "Massachusetts Badminton Foundation" } = Astro.props;
const path = Astro.url.pathname;

let customPages: { label: string; slug: string }[] = [];
try {
  customPages = JSON.parse(await readFile(join(process.cwd(), "src/data/pages.json"), "utf-8"));
} catch {}

const navLinks = [
  { label: "Home", href: "/" },
  { label: "About Us", href: "/about" },
  { label: "Events", href: "/events" },
  { label: "PCA", href: "/pca" },
  { label: "Sponsors", href: "/sponsors" },
  ...customPages.map((p) => ({ label: p.label, href: `/${p.slug}` })),
];

function isActive(href: string) {
  if (href === "/") return path === "/";
  return path.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Massachusetts Badminton Foundation</title>
  </head>
  <body style="display:flex;flex-direction:column;min-height:100vh;">

    <header class="mbf-header">
      <div class="mbf-header-inner">
        <div class="mbf-header-row">
          <a href="/" style="display:flex;align-items:center;gap:0.75rem;text-decoration:none;flex-shrink:0;">
            <img src="/logo.png" alt="MBF Logo" class="mbf-logo" />
            <div class="mbf-logo-text">
              <div class="mbf-logo-text-main">Massachusetts</div>
              <div class="mbf-logo-text-sub">Badminton Foundation</div>
            </div>
          </a>
          <div style="flex:1;"></div>
          <!-- Hamburger (mobile only) -->
          <button
            id="nav-toggle"
            class="mbf-hamburger"
            aria-label="Toggle navigation"
            aria-expanded="false"
            onclick="toggleMobileNav()"
          >
            <span></span><span></span><span></span>
          </button>
          <!-- Nav -->
          <nav id="main-nav" class="mbf-nav">
            {navLinks.map(link => (
              <a href={link.href} class={`mbf-nav-link ${isActive(link.href) ? "active" : ""}`}>
                {link.label}
              </a>
            ))}
            <a href="/donate" class="mbf-donate-btn" style="margin-left:0.5rem;">Donate</a>
          </nav>
        </div>
      </div>
    </header>

    <!-- Admin Modal -->
    <div id="admin-modal" style="display:none;position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center;background:rgba(0,0,0,0.55);">
      <div style="background:white;border-radius:12px;padding:2rem;max-width:380px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,0.3);margin:1rem;box-sizing:border-box;">

        <!-- Login View -->
        <div id="admin-login-view">
          <h2 style="font-size:1.2rem;font-weight:700;color:#1B3A8F;margin:0 0 1.25rem;">Admin Login</h2>
          <div style="margin-bottom:1rem;">
            <label style="font-size:0.82rem;font-weight:600;color:#374151;display:block;margin-bottom:0.4rem;">Password</label>
            <div style="position:relative;">
              <input
                type="password"
                id="admin-password"
                placeholder="Enter admin password"
                style="width:100%;padding:0.6rem 3rem 0.6rem 0.8rem;border:1px solid #D1D5DB;border-radius:6px;font-size:0.9rem;box-sizing:border-box;outline:none;"
                onkeydown="if(event.key==='Enter')window.adminLogin();"
              />
              <button
                type="button"
                id="pw-toggle"
                onclick="window.toggleAdminPw()"
                aria-label="Show or hide password"
                style="position:absolute;right:0;top:0;bottom:0;width:2.75rem;background:none;border:none;cursor:pointer;color:#9CA3AF;padding:0;display:flex;align-items:center;justify-content:center;"
              >
                <!-- eye-open (default) -->
                <svg id="pw-eye-open" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                <!-- eye-off (hidden by default) -->
                <svg id="pw-eye-off" style="display:none" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/>
                  <line x1="1" y1="1" x2="23" y2="23"/>
                </svg>
              </button>
            </div>
          </div>
          <div id="admin-login-error" style="color:#CC2222;font-size:0.82rem;margin-bottom:0.75rem;display:none;">
            Incorrect password. Please try again.
          </div>
          <div style="display:flex;gap:0.75rem;">
            <button
              onclick="window.adminLogin()"
              style="flex:1;background:#1B3A8F;color:white;border:none;padding:0.65rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.9rem;"
            >Log In</button>
            <button
              onclick="document.getElementById('admin-modal').style.display='none'"
              style="padding:0.65rem 1rem;border:1px solid #D1D5DB;background:white;border-radius:6px;cursor:pointer;font-size:0.9rem;"
            >Cancel</button>
          </div>
        </div>

        <!-- Logged-In View -->
        <div id="admin-loggedin-view" style="display:none;">
          <h2 style="font-size:1.2rem;font-weight:700;color:#1B3A8F;margin:0 0 0.5rem;">Admin Panel</h2>
          <p style="font-size:0.9rem;color:#4B5563;margin:0 0 1rem;">You are logged in as administrator.</p>
          <button
            onclick="document.getElementById('admin-modal').style.display='none'; openPagesManager();"
            style="width:100%;background:#EEF2FF;color:#1B3A8F;border:1px solid #C7D2FE;padding:0.6rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.88rem;margin-bottom:0.75rem;text-align:left;"
          >📄 Manage Custom Pages</button>
          <div style="display:flex;gap:0.75rem;">
            <button
              onclick="window.adminLogout()"
              style="flex:1;background:#CC2222;color:white;border:none;padding:0.65rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.9rem;"
            >Log Out</button>
            <button
              onclick="document.getElementById('admin-modal').style.display='none'"
              style="padding:0.65rem 1rem;border:1px solid #D1D5DB;background:white;border-radius:6px;cursor:pointer;font-size:0.9rem;"
            >Close</button>
          </div>
        </div>

      </div>
    </div>

    <!-- Admin corner button -->
    <button
      id="admin-btn"
      onclick="document.getElementById('admin-modal').style.display='flex'"
      style="position:fixed;top:10px;right:12px;z-index:9998;background:#1a3070;background:rgba(255,255,255,0.12);color:rgba(255,255,255,0.65);border:1px solid rgba(255,255,255,0.2);border-radius:5px;padding:0.2rem 0.55rem;font-size:0.68rem;font-weight:600;cursor:pointer;letter-spacing:0.04em;-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px);transition:all 0.15s;min-height:28px;"
      onmouseover="this.style.background='rgba(255,255,255,0.22)';this.style.color='white'"
      onmouseout="this.style.background='rgba(255,255,255,0.12)';this.style.color='rgba(255,255,255,0.65)'"
    >Admin</button>

    <!-- Confirm Dialog Modal -->
    <div id="mbf-confirm-modal" style="display:none;position:fixed;inset:0;z-index:10001;align-items:center;justify-content:center;background:rgba(0,0,0,0.55);">
      <div style="background:white;border-radius:14px;padding:2rem 2rem 1.75rem;max-width:380px;width:100%;box-shadow:0 24px 64px rgba(0,0,0,0.3);margin:1rem;box-sizing:border-box;text-align:center;">
        <div id="mbf-confirm-icon" style="font-size:2.5rem;margin-bottom:0.75rem;">🗑️</div>
        <h3 id="mbf-confirm-title" style="font-size:1.1rem;font-weight:700;color:#1B3A8F;margin:0 0 0.6rem;"></h3>
        <p id="mbf-confirm-msg" style="font-size:0.88rem;color:#4B5563;margin:0 0 1.5rem;line-height:1.6;"></p>
        <div style="display:flex;gap:0.75rem;">
          <button id="mbf-confirm-cancel" style="flex:1;padding:0.65rem;border:1px solid #D1D5DB;background:white;border-radius:8px;cursor:pointer;font-size:0.9rem;font-weight:600;color:#374151;">Cancel</button>
          <button id="mbf-confirm-ok" style="flex:1;background:#CC2222;color:white;border:none;padding:0.65rem;border-radius:8px;font-weight:700;cursor:pointer;font-size:0.9rem;">Delete</button>
        </div>
      </div>
    </div>

    <!-- Pages Manager Modal -->
    <div id="pages-manager-modal" style="display:none;position:fixed;inset:0;z-index:9999;align-items:flex-start;justify-content:center;background:rgba(0,0,0,0.55);overflow-y:auto;padding:2rem 1rem;">
      <div style="background:white;border-radius:12px;max-width:580px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,0.3);box-sizing:border-box;margin:auto;overflow:hidden;">

        <!-- Header -->
        <div style="background:linear-gradient(135deg,#1B3A8F,#122970);padding:1.25rem 1.5rem;display:flex;align-items:center;justify-content:space-between;">
          <h2 style="font-size:1.1rem;font-weight:700;color:white;margin:0;">📄 Manage Custom Pages</h2>
          <button onclick="closePagesManager()" style="background:rgba(255,255,255,0.15);border:none;color:white;width:30px;height:30px;border-radius:50%;cursor:pointer;font-size:1.1rem;line-height:1;display:flex;align-items:center;justify-content:center;">✕</button>
        </div>

        <div style="padding:1.5rem;">
          <!-- Existing pages list -->
          <div id="pm-pages-list" style="margin-bottom:1.25rem;"></div>

          <!-- Add / Edit form -->
          <div id="pm-form" style="background:#F8FAFF;border:1px solid #E0E7FF;border-radius:8px;padding:1.25rem;">
            <h3 id="pm-form-title" style="font-size:0.95rem;font-weight:700;color:#1B3A8F;margin:0 0 1rem;">+ Add New Page</h3>
            <input type="hidden" id="pm-id" />
            <div style="display:flex;flex-direction:column;gap:0.85rem;">

              <div>
                <label style="font-size:0.8rem;font-weight:600;color:#374151;display:block;margin-bottom:0.35rem;">Tab Label *</label>
                <input type="text" id="pm-label" placeholder="e.g., Resources"
                  oninput="pmAutoSlug()"
                  style="width:100%;padding:0.55rem 0.75rem;border:1px solid #D1D5DB;border-radius:6px;font-size:0.9rem;box-sizing:border-box;" />
              </div>

              <div>
                <label style="font-size:0.8rem;font-weight:600;color:#374151;display:block;margin-bottom:0.35rem;">
                  URL Path *
                  <span style="font-weight:400;color:#9CA3AF;font-size:0.75rem;"> — appears as massbf.org/<span id="pm-slug-preview" style="color:#1B3A8F;font-weight:600;">…</span></span>
                </label>
                <input type="text" id="pm-slug" placeholder="resources"
                  oninput="pmUpdateSlugPreview()"
                  style="width:100%;padding:0.55rem 0.75rem;border:1px solid #D1D5DB;border-radius:6px;font-size:0.9rem;box-sizing:border-box;font-family:monospace;" />
              </div>

              <div>
                <label style="font-size:0.8rem;font-weight:600;color:#374151;display:block;margin-bottom:0.35rem;">Page Content</label>
                <textarea id="pm-content" rows="6" placeholder="Enter the text content for this page. Use a blank line between paragraphs."
                  style="width:100%;padding:0.55rem 0.75rem;border:1px solid #D1D5DB;border-radius:6px;font-size:0.88rem;box-sizing:border-box;resize:vertical;font-family:inherit;line-height:1.6;"></textarea>
                <div style="font-size:0.72rem;color:#9CA3AF;margin-top:0.25rem;">Tip: Leave a blank line between paragraphs to split them on the page.</div>
              </div>

              <div id="pm-error" style="color:#CC2222;font-size:0.82rem;display:none;"></div>
              <div style="display:flex;gap:0.65rem;">
                <button onclick="savePage()" style="flex:1;background:#1B3A8F;color:white;border:none;padding:0.6rem;border-radius:6px;font-weight:700;cursor:pointer;font-size:0.88rem;">Save Page</button>
                <button onclick="pmResetForm()" style="padding:0.6rem 1rem;border:1px solid #D1D5DB;background:white;border-radius:6px;cursor:pointer;font-size:0.88rem;">Clear</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <main style="flex:1;">
      <slot />
    </main>

    <footer class="mbf-footer" style="padding:2rem 0;">
      <div style="max-width:1200px;margin:0 auto;padding:0 1.5rem;">
        <div style="display:flex;flex-wrap:wrap;gap:2rem;justify-content:space-between;align-items:flex-start;">
          <div>
            <img src="/logo.png" alt="MBF Logo" style="height:44px;width:auto;margin-bottom:0.75rem;opacity:0.9;" />
            <p style="font-size:0.85rem;margin:0.25rem 0;">Massachusetts Badminton Foundation (MBF)</p>
            <p style="font-size:0.8rem;margin:0.25rem 0;opacity:0.7;">EIN: 39-4717851 | 501(c)(3) Tax-Exempt Organization</p>
          </div>
          <div style="font-size:0.85rem;">
            <p style="margin:0.25rem 0;font-weight:600;color:rgba(255,255,255,0.95);">Contact</p>
            <p style="margin:0.25rem 0;opacity:0.8;">80 Broadmeadow Street, Marlborough, MA 01752</p>
            <p style="margin:0.25rem 0;opacity:0.8;">larryzhang07@gmail.com</p>

            <!-- Social icons -->
            <div id="social-row" style="display:flex;gap:0.65rem;margin-top:0.9rem;align-items:center;">
              <!-- Facebook -->
              <a id="social-fb" href="#" target="_blank" rel="noopener" title="Facebook"
                style="display:none;width:36px;height:36px;border-radius:50%;background:#1877F2;color:white;align-items:center;justify-content:center;flex-shrink:0;text-decoration:none;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              </a>
              <!-- Instagram -->
              <a id="social-ig" href="#" target="_blank" rel="noopener" title="Instagram"
                style="display:none;width:36px;height:36px;border-radius:50%;background:radial-gradient(circle at 30% 110%,#f09433 0%,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888 100%);color:white;align-items:center;justify-content:center;flex-shrink:0;text-decoration:none;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </a>
              <!-- YouTube -->
              <a id="social-yt" href="#" target="_blank" rel="noopener" title="YouTube"
                style="display:none;width:36px;height:36px;border-radius:50%;background:#FF0000;color:white;align-items:center;justify-content:center;flex-shrink:0;text-decoration:none;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                  <polygon fill="white" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
                </svg>
              </a>
            </div>

            <!-- Admin: Edit Social Links button (hidden until admin logged in) -->
            <button id="social-edit-btn" onclick="openSocialEditor()"
              style="display:none;margin-top:0.65rem;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.25);color:rgba(255,255,255,0.8);font-size:0.72rem;font-weight:600;padding:0.3rem 0.75rem;border-radius:5px;cursor:pointer;letter-spacing:0.03em;">
              ✎ Edit Social Links
            </button>
          </div>

          <!-- Social Links Editor (admin only, inline) -->
          <div id="social-editor" style="display:none;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.18);border-radius:10px;padding:1rem 1.25rem;font-size:0.83rem;min-width:240px;">
            <p style="margin:0 0 0.75rem;font-weight:700;color:rgba(255,255,255,0.95);font-size:0.85rem;">Social Media Links</p>

            <div style="display:flex;flex-direction:column;gap:0.55rem;">
              <div style="display:flex;align-items:center;gap:0.5rem;">
                <span style="width:28px;height:28px;border-radius:50%;background:#1877F2;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                </span>
                <input id="se-facebook" type="url" placeholder="Facebook page URL"
                  style="flex:1;padding:0.35rem 0.55rem;border-radius:5px;border:1px solid rgba(255,255,255,0.25);background:rgba(255,255,255,0.1);color:white;font-size:0.8rem;min-width:0;"
                  oninput="this.style.borderColor=this.value?'#4ADE80':'rgba(255,255,255,0.25)'" />
              </div>
              <div style="display:flex;align-items:center;gap:0.5rem;">
                <span style="width:28px;height:28px;border-radius:50%;background:radial-gradient(circle at 30% 110%,#f09433,#dc2743 50%,#bc1888);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                </span>
                <input id="se-instagram" type="url" placeholder="Instagram profile URL"
                  style="flex:1;padding:0.35rem 0.55rem;border-radius:5px;border:1px solid rgba(255,255,255,0.25);background:rgba(255,255,255,0.1);color:white;font-size:0.8rem;min-width:0;"
                  oninput="this.style.borderColor=this.value?'#4ADE80':'rgba(255,255,255,0.25)'" />
              </div>
              <div style="display:flex;align-items:center;gap:0.5rem;">
                <span style="width:28px;height:28px;border-radius:50%;background:#FF0000;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon fill="white" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
                </span>
                <input id="se-youtube" type="url" placeholder="YouTube channel URL"
                  style="flex:1;padding:0.35rem 0.55rem;border-radius:5px;border:1px solid rgba(255,255,255,0.25);background:rgba(255,255,255,0.1);color:white;font-size:0.8rem;min-width:0;"
                  oninput="this.style.borderColor=this.value?'#4ADE80':'rgba(255,255,255,0.25)'" />
              </div>
            </div>

            <div id="se-status" style="font-size:0.75rem;margin-top:0.5rem;min-height:1rem;"></div>
            <div style="display:flex;gap:0.5rem;margin-top:0.6rem;">
              <button onclick="saveSocialLinks()"
                style="flex:1;background:#1B3A8F;color:white;border:none;padding:0.4rem;border-radius:5px;font-size:0.8rem;font-weight:700;cursor:pointer;">Save</button>
              <button onclick="closeSocialEditor()"
                style="padding:0.4rem 0.75rem;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.8);border-radius:5px;font-size:0.8rem;cursor:pointer;">Cancel</button>
            </div>
          </div>
          <div style="font-size:0.85rem;">
            <p style="margin:0.25rem 0;font-weight:600;color:rgba(255,255,255,0.95);">Quick Links</p>
            {navLinks.map(link => (
              <a href={link.href} style="display:block;margin:0.2rem 0;color:rgba(255,255,255,0.7);text-decoration:none;" onmouseover="this.style.color='#F37021'" onmouseout="this.style.color='rgba(255,255,255,0.7)'">{link.label}</a>
            ))}
          </div>
        </div>
        <div style="border-top:1px solid rgba(255,255,255,0.15);margin-top:1.5rem;padding-top:1rem;font-size:0.78rem;opacity:0.6;text-align:center;">
          &copy; {new Date().getFullYear()} Massachusetts Badminton Foundation. All rights reserved.
        </div>
      </div>
    </footer>

    <script>
      async function checkAdminStatus() {
        const token = sessionStorage.getItem('mbf_admin_token');
        const adminBtn = document.getElementById('admin-btn');
        const loginView = document.getElementById('admin-login-view');
        const loggedinView = document.getElementById('admin-loggedin-view');

        if (!token) {
          document.body.dataset.admin = 'false';
          return;
        }

        try {
          const res = await fetch('/api/auth', { headers: { 'X-Admin-Token': token } });
          const data = await res.json();
          if (data.valid) {
            if (adminBtn) {
              adminBtn.textContent = '⚙ Admin';
              adminBtn.style.background = 'rgba(243,112,33,0.25)';
              adminBtn.style.borderColor = 'rgba(243,112,33,0.6)';
              adminBtn.style.color = '#FDBA74';
            }
            document.body.dataset.admin = 'true';
            if (loginView) loginView.style.display = 'none';
            if (loggedinView) loggedinView.style.display = 'block';
            document.dispatchEvent(new CustomEvent('mbf:admin-ready'));
          } else {
            sessionStorage.removeItem('mbf_admin_token');
            document.body.dataset.admin = 'false';
          }
        } catch {
          document.body.dataset.admin = 'false';
        }
      }

      window.adminLogin = async function() {
        const pwEl = document.getElementById('admin-password') as HTMLInputElement;
        const errorEl = document.getElementById('admin-login-error');
        const password = pwEl ? pwEl.value : '';
        try {
          const res = await fetch('/api/auth', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password })
          });
          const data = await res.json();
          if (data.success && data.token) {
            sessionStorage.setItem('mbf_admin_token', data.token);
            document.getElementById('admin-modal')!.style.display = 'none';
            location.reload();
          } else {
            if (errorEl) errorEl.style.display = 'block';
          }
        } catch {
          if (errorEl) errorEl.style.display = 'block';
        }
      };

      window.adminLogout = async function() {
        sessionStorage.removeItem('mbf_admin_token');
        location.reload();
      };

      const _adminModal = document.getElementById('admin-modal')!;
      _adminModal.addEventListener('click', function(e) {
        if (e.target === this) { this.style.display = 'none'; resetAdminModal(); }
      });
      // Also reset when Cancel buttons are clicked
      _adminModal.querySelectorAll('button').forEach(btn => {
        if (btn.textContent?.trim() === 'Cancel') {
          btn.addEventListener('click', resetAdminModal);
        }
      });

      checkAdminStatus();

      // ── Pages Manager ──────────────────────────────────────────────
      let pmSlugLocked = false; // stop auto-slug once user manually edits it

      function pmToSlug(s: string): string {
        return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      }
      window.pmAutoSlug = function() {
        if (pmSlugLocked) return;
        const label = (document.getElementById('pm-label') as HTMLInputElement).value;
        const slug = pmToSlug(label);
        (document.getElementById('pm-slug') as HTMLInputElement).value = slug;
        document.getElementById('pm-slug-preview')!.textContent = slug || '…';
      };
      window.pmUpdateSlugPreview = function() {
        pmSlugLocked = true;
        const slug = (document.getElementById('pm-slug') as HTMLInputElement).value;
        document.getElementById('pm-slug-preview')!.textContent = slug || '…';
      };

      function pmResetForm() {
        (document.getElementById('pm-id') as HTMLInputElement).value = '';
        (document.getElementById('pm-label') as HTMLInputElement).value = '';
        (document.getElementById('pm-slug') as HTMLInputElement).value = '';
        (document.getElementById('pm-content') as HTMLTextAreaElement).value = '';
        document.getElementById('pm-slug-preview')!.textContent = '…';
        document.getElementById('pm-form-title')!.textContent = '+ Add New Page';
        document.getElementById('pm-error')!.style.display = 'none';
        pmSlugLocked = false;
      }
      window.pmResetForm = pmResetForm;

      async function pmLoadPages() {
        const listEl = document.getElementById('pm-pages-list')!;
        const res = await fetch('/api/pages');
        const pages: any[] = await res.json();
        if (!pages.length) {
          listEl.innerHTML = '<p style="font-size:0.85rem;color:#9CA3AF;text-align:center;padding:0.5rem 0 0.75rem;">No custom pages yet. Add one below.</p>';
          return;
        }
        listEl.innerHTML = `<div style="font-size:0.78rem;font-weight:700;color:#6B7280;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.5rem;">Current Pages</div>` +
          pages.map(p => `
          <div style="display:flex;align-items:center;gap:0.6rem;padding:0.6rem 0.75rem;background:#F8FAFF;border:1px solid #E0E7FF;border-radius:7px;margin-bottom:0.4rem;">
            <div style="flex:1;min-width:0;">
              <div style="font-size:0.88rem;font-weight:700;color:#1B3A8F;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${p.label}</div>
              <div style="font-size:0.75rem;color:#9CA3AF;font-family:monospace;">/${p.slug}</div>
            </div>
            <a href="/${p.slug}" target="_blank" style="font-size:0.72rem;color:#1B3A8F;text-decoration:none;background:#EEF2FF;border:1px solid #C7D2FE;padding:0.25rem 0.5rem;border-radius:4px;flex-shrink:0;">View ↗</a>
            <button onclick='pmEditPage(${JSON.stringify(p).replace(/'/g,"&#39;")})'
              style="background:#EEF2FF;color:#1B3A8F;border:1px solid #C7D2FE;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.75rem;font-weight:600;cursor:pointer;flex-shrink:0;">Edit</button>
            <button onclick="pmDeletePage('${p.id}')"
              style="background:#FEF2F2;color:#CC2222;border:1px solid #FECACA;padding:0.25rem 0.6rem;border-radius:4px;font-size:0.75rem;font-weight:600;cursor:pointer;flex-shrink:0;">Delete</button>
          </div>`).join('');
      }

      window.pmEditPage = function(p: any) {
        (document.getElementById('pm-id') as HTMLInputElement).value = p.id;
        (document.getElementById('pm-label') as HTMLInputElement).value = p.label;
        (document.getElementById('pm-slug') as HTMLInputElement).value = p.slug;
        (document.getElementById('pm-content') as HTMLTextAreaElement).value = p.content || '';
        document.getElementById('pm-slug-preview')!.textContent = p.slug;
        document.getElementById('pm-form-title')!.textContent = `Edit: ${p.label}`;
        document.getElementById('pm-error')!.style.display = 'none';
        pmSlugLocked = true;
        document.getElementById('pm-label')!.scrollIntoView({ behavior: 'smooth', block: 'center' });
      };

      window.savePage = async function() {
        const id      = (document.getElementById('pm-id') as HTMLInputElement).value;
        const label   = (document.getElementById('pm-label') as HTMLInputElement).value.trim();
        const slug    = (document.getElementById('pm-slug') as HTMLInputElement).value.trim();
        const content = (document.getElementById('pm-content') as HTMLTextAreaElement).value.trim();
        const errEl   = document.getElementById('pm-error')!;
        errEl.style.display = 'none';
        if (!label || !slug) { errEl.textContent = 'Tab label and URL path are required.'; errEl.style.display = 'block'; return; }
        const token = sessionStorage.getItem('mbf_admin_token') || '';
        const res = await fetch('/api/pages', {
          method: id ? 'PUT' : 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Admin-Token': token },
          body: JSON.stringify(id ? { id, label, slug, content } : { label, slug, content }),
        });
        if (res.ok) {
          pmResetForm();
          await pmLoadPages();
        } else {
          const err = await res.json();
          errEl.textContent = err.error || 'Save failed. Please try again.';
          errEl.style.display = 'block';
        }
      };

      window.pmDeletePage = async function(id: string) {
        const confirmed = await window.mbfConfirm(
          'This page and its content will be permanently removed. The tab will disappear from the navigation.',
          'Delete Page?', 'Delete', '📄'
        );
        if (!confirmed) return;
        const token = sessionStorage.getItem('mbf_admin_token') || '';
        const res = await fetch(`/api/pages?id=${id}`, { method: 'DELETE', headers: { 'X-Admin-Token': token } });
        if (res.ok) { pmResetForm(); await pmLoadPages(); }
      };

      window.openPagesManager = async function() {
        pmResetForm();
        document.getElementById('pages-manager-modal')!.style.display = 'flex';
        await pmLoadPages();
      };
      window.closePagesManager = function() {
        document.getElementById('pages-manager-modal')!.style.display = 'none';
      };
      document.getElementById('pages-manager-modal')!.addEventListener('click', function(e) {
        if (e.target === this) closePagesManager();
      });

      // ── Social Links ───────────────────────────────────────────────
      async function loadSocialLinks() {
        try {
          const data = await (await fetch('/api/settings')).json();
          const s = data.social || {};
          const fb = document.getElementById('social-fb') as HTMLAnchorElement;
          const ig = document.getElementById('social-ig') as HTMLAnchorElement;
          const yt = document.getElementById('social-yt') as HTMLAnchorElement;
          if (fb) { if (s.facebook) { fb.href = s.facebook; fb.style.display = 'flex'; } else fb.style.display = 'none'; }
          if (ig) { if (s.instagram) { ig.href = s.instagram; ig.style.display = 'flex'; } else ig.style.display = 'none'; }
          if (yt) { if (s.youtube)   { yt.href = s.youtube;   yt.style.display = 'flex'; } else yt.style.display = 'none'; }
          // Pre-fill editor inputs
          const seFb = document.getElementById('se-facebook') as HTMLInputElement;
          const seIg = document.getElementById('se-instagram') as HTMLInputElement;
          const seYt = document.getElementById('se-youtube')  as HTMLInputElement;
          if (seFb) { seFb.value = s.facebook || ''; seFb.style.borderColor = s.facebook ? '#4ADE80' : 'rgba(255,255,255,0.25)'; }
          if (seIg) { seIg.value = s.instagram || ''; seIg.style.borderColor = s.instagram ? '#4ADE80' : 'rgba(255,255,255,0.25)'; }
          if (seYt) { seYt.value = s.youtube || '';   seYt.style.borderColor = s.youtube   ? '#4ADE80' : 'rgba(255,255,255,0.25)'; }
        } catch {}
      }
      loadSocialLinks();

      window.openSocialEditor = function() {
        document.getElementById('social-editor')!.style.display = 'block';
        document.getElementById('social-edit-btn')!.style.display = 'none';
        document.getElementById('se-status')!.textContent = '';
      };
      window.closeSocialEditor = function() {
        document.getElementById('social-editor')!.style.display = 'none';
        document.getElementById('social-edit-btn')!.style.display = 'block';
      };
      window.saveSocialLinks = async function() {
        const fb = (document.getElementById('se-facebook') as HTMLInputElement).value.trim();
        const ig = (document.getElementById('se-instagram') as HTMLInputElement).value.trim();
        const yt = (document.getElementById('se-youtube')  as HTMLInputElement).value.trim();
        const status = document.getElementById('se-status')!;
        const token = sessionStorage.getItem('mbf_admin_token') || '';
        status.textContent = 'Saving…'; status.style.color = 'rgba(255,255,255,0.6)';
        try {
          const res = await fetch('/api/settings', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json', 'X-Admin-Token': token },
            body: JSON.stringify({ social: { facebook: fb, instagram: ig, youtube: yt } })
          });
          if (res.ok) {
            status.textContent = '✓ Saved!'; status.style.color = '#4ADE80';
            await loadSocialLinks();
            setTimeout(() => { closeSocialEditor(); }, 900);
          } else {
            status.textContent = 'Save failed.'; status.style.color = '#F87171';
          }
        } catch {
          status.textContent = 'Save failed.'; status.style.color = '#F87171';
        }
      };

      // Show admin social button on login
      document.addEventListener('mbf:admin-ready', () => {
        const btn = document.getElementById('social-edit-btn');
        if (btn) btn.style.display = 'block';
      });
      if (document.body.dataset.admin === 'true') {
        const btn = document.getElementById('social-edit-btn');
        if (btn) btn.style.display = 'block';
      }

      // Password show/hide toggle
      window.toggleAdminPw = function() {
        const input = document.getElementById('admin-password') as HTMLInputElement;
        const btn = document.getElementById('pw-toggle')!;
        const eyeOpen = document.getElementById('pw-eye-open')!;
        const eyeOff  = document.getElementById('pw-eye-off')!;
        const showing = input.type === 'text';
        input.type = showing ? 'password' : 'text';
        eyeOpen.style.display = showing ? '' : 'none';
        eyeOff.style.display  = showing ? 'none' : '';
        btn.style.color = showing ? '#9CA3AF' : '#1B3A8F';
      };
      // Reset password field when admin modal closes
      function resetAdminModal() {
        const input   = document.getElementById('admin-password') as HTMLInputElement;
        const btn     = document.getElementById('pw-toggle')!;
        const eyeOpen = document.getElementById('pw-eye-open')!;
        const eyeOff  = document.getElementById('pw-eye-off')!;
        if (input) { input.value = ''; input.type = 'password'; }
        if (eyeOpen) eyeOpen.style.display = '';
        if (eyeOff)  eyeOff.style.display  = 'none';
        if (btn) btn.style.color = '#9CA3AF';
        const err = document.getElementById('admin-login-error');
        if (err) err.style.display = 'none';
      }

      // Mobile nav toggle
      window.toggleMobileNav = function() {
        const nav = document.getElementById('main-nav')!;
        const btn = document.getElementById('nav-toggle')!;
        const isOpen = nav.classList.toggle('open');
        btn.classList.toggle('open', isOpen);
        btn.setAttribute('aria-expanded', String(isOpen));
      };
      // Close nav when any link is tapped on mobile
      document.getElementById('main-nav')!.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          const nav = document.getElementById('main-nav')!;
          const btn = document.getElementById('nav-toggle')!;
          nav.classList.remove('open');
          btn.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
        });
      });

      // Shared confirm dialog
      window.mbfConfirm = function(message: string, title?: string, confirmText?: string, icon?: string): Promise<boolean> {
        return new Promise(resolve => {
          const modal = document.getElementById('mbf-confirm-modal')!;
          (document.getElementById('mbf-confirm-title')! as HTMLElement).textContent = title || 'Are you sure?';
          (document.getElementById('mbf-confirm-msg')! as HTMLElement).textContent = message;
          (document.getElementById('mbf-confirm-icon')! as HTMLElement).textContent = icon || '🗑️';
          const okBtn = document.getElementById('mbf-confirm-ok')!;
          okBtn.textContent = confirmText || 'Delete';
          modal.style.display = 'flex';

          function cleanup() { modal.style.display = 'none'; }

          okBtn.addEventListener('click', () => { cleanup(); resolve(true); }, { once: true });
          document.getElementById('mbf-confirm-cancel')!.addEventListener('click', () => { cleanup(); resolve(false); }, { once: true });
          modal.addEventListener('click', function handler(e) {
            if (e.target === modal) { modal.removeEventListener('click', handler); cleanup(); resolve(false); }
          });
        });
      };
    </script>

  </body>
</html>
