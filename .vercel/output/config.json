{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/officers/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/pages/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/photos/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/settings/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/sponsor-events/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/sponsors/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/tournaments/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/upload/?$",
			"dest": "_render"
		},
		{
			"src": "^/donate/?$",
			"dest": "_render"
		},
		{
			"src": "^/events/?$",
			"dest": "_render"
		},
		{
			"src": "^/pca/?$",
			"dest": "_render"
		},
		{
			"src": "^/sponsors/?$",
			"dest": "_render"
		},
		{
			"src": "^/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}